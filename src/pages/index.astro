---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Relaybox — Chat experience, built for your terminal.</title>
    <meta name="description" content="A Spotlight-style panel for Claude Code, Cursor, and any terminal. Double-tap Option, type, send." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 h-[72px] bg-[#F5F4F1]/90 backdrop-blur-sm border-b border-[#E5E4DF]">
      <div class="flex items-center gap-2.5">
        <img src="/logo.svg" alt="Relaybox" class="w-7 h-7" />
        <span class="font-semibold text-[#1C1C1C] text-[15px]" style="font-family: 'Bricolage Grotesque', sans-serif;">Relaybox</span>
      </div>
      <div class="flex items-center gap-8">
        <a href="#features" class="text-sm text-[#6B6B6B] hover:text-[#1C1C1C] transition-colors">Features</a>
        <a
          href="https://github.com/k-yoneda0614/relaybox/releases"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#F08C00] text-white text-sm font-semibold hover:bg-[#E07D00] transition-colors"
        >
          Download for macOS
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="pt-[72px] min-h-screen flex items-center">
      <div class="max-w-[1280px] mx-auto px-8 w-full flex items-center gap-16">
        <!-- Left -->
        <div class="flex flex-col gap-8 flex-shrink-0 w-[460px]">
          <div class="flex flex-col gap-4">
            <h1 class="text-[56px] font-extrabold leading-[1.05] tracking-[-0.02em] text-[#1C1C1C]" style="font-family: 'Bricolage Grotesque', sans-serif;">
              Chat experience,<br />
              <span class="text-[#F08C00]">built for your<br />terminal.</span>
            </h1>
            <p class="text-[17px] text-[#6B6B6B] leading-[1.7]" style="font-family: 'Inter', sans-serif;">
              Works with Claude Code, Cursor, and any terminal.<br />
              Just open your RelayBox and type like chat-based AI.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a
              href="https://github.com/k-yoneda0614/relaybox/releases"
              class="inline-flex items-center gap-2.5 px-6 py-3.5 rounded-full bg-[#F08C00] text-white font-semibold text-[15px] hover:bg-[#E07D00] transition-colors w-fit"
              style="font-family: 'Inter', sans-serif;"
            >
              Download for macOS
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M3 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M1 11h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </a>
            <p class="text-xs text-[#9B9B9B]" style="font-family: 'Inter', sans-serif;">Requires macOS 13.0+</p>
          </div>
        </div>

        <!-- Right: Product mockup -->
        <div class="flex-1 flex items-center justify-center">
          <img
            src="/hero-mockup.webp"
            alt="Relaybox panel with terminal"
            class="w-full max-w-[660px] h-auto drop-shadow-2xl"
          />
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-32 max-w-[1280px] mx-auto px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold tracking-[0.1em] uppercase text-[#F08C00] mb-4" style="font-family: 'Inter', sans-serif;">Features</p>
        <h2 class="text-[42px] font-bold leading-[1.15] tracking-[-0.01em] text-[#1C1C1C] mb-4" style="font-family: 'Bricolage Grotesque', sans-serif;">
          Everything you need,<br />nothing you don't.
        </h2>
        <p class="text-[17px] text-[#6B6B6B] leading-[1.7]" style="font-family: 'Inter', sans-serif;">
          Relaybox strips away friction. Three keystrokes cover every workflow.
        </p>
      </div>

      <div class="grid grid-cols-3 gap-4">
        <!-- Hotkey -->
        <div class="rounded-[20px] p-8 flex flex-col gap-6" style="background: #1C1C1E;">
          <div class="w-10 h-10 rounded-[10px] bg-[#F08C00]/15 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="6" height="6" rx="1.5" stroke="#F08C00" stroke-width="1.5"/><rect x="10" y="2" width="6" height="6" rx="1.5" stroke="#F08C00" stroke-width="1.5"/><rect x="2" y="10" width="6" height="6" rx="1.5" stroke="#F08C00" stroke-width="1.5"/><rect x="10" y="10" width="6" height="6" rx="1.5" stroke="#F08C00" stroke-width="1.5"/></svg>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex gap-1.5">
              <kbd class="px-2.5 py-1.5 rounded-[6px] text-white/70 text-[12px] font-mono border border-white/10" style="background: rgba(255,255,255,0.08);">⌥</kbd>
              <kbd class="px-2.5 py-1.5 rounded-[6px] text-white/70 text-[12px] font-mono border border-white/10" style="background: rgba(255,255,255,0.08);">⌥</kbd>
            </div>
            <span class="text-white/30 text-[12px]" style="font-family: 'Inter', sans-serif;">× 2</span>
          </div>
          <div>
            <h3 class="text-[20px] font-bold text-white mb-2 leading-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">Instant hotkey.<br />Always ready.</h3>
            <p class="text-[14px] text-white/50 leading-[1.7]" style="font-family: 'Inter', sans-serif;">Double-tap Option from anywhere. No dock, no menu bar click. The panel appears right where you're working.</p>
          </div>
        </div>

        <!-- Slash commands -->
        <div class="rounded-[20px] p-8 flex flex-col gap-6" style="background: #FDF3E3;">
          <div class="w-10 h-10 rounded-[10px] bg-[#F08C00]/15 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 3L7 15" stroke="#F08C00" stroke-width="1.8" stroke-linecap="round"/><path d="M4 7h10" stroke="#F08C00" stroke-width="1.5" stroke-linecap="round"/><path d="M4 11h10" stroke="#F08C00" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 rounded-full bg-[#F08C00] text-white text-[12px] font-semibold" style="font-family: 'Inter', sans-serif;">/commit</span>
            <span class="px-2.5 py-1 rounded-full bg-[#F08C00]/15 text-[#F08C00] text-[12px] font-semibold" style="font-family: 'Inter', sans-serif;">/review</span>
            <span class="px-2.5 py-1 rounded-full bg-[#F08C00]/15 text-[#F08C00] text-[12px] font-semibold" style="font-family: 'Inter', sans-serif;">/explain</span>
          </div>
          <div>
            <h3 class="text-[20px] font-bold text-[#1C1C1C] mb-2 leading-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">Slash commands.<br />Skills at your fingertips.</h3>
            <p class="text-[14px] text-[#6B6B6B] leading-[1.7]" style="font-family: 'Inter', sans-serif;">Type / to browse pre-built skills — commit messages, code reviews, explanations. Build your own library.</p>
          </div>
        </div>

        <!-- File mention -->
        <div class="rounded-[20px] p-8 flex flex-col gap-6" style="background: #EFF4FF;">
          <div class="w-10 h-10 rounded-[10px] bg-[#007AFF]/15 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="#007AFF" stroke-width="1.5"/><path d="M9 8v5" stroke="#007AFF" stroke-width="1.8" stroke-linecap="round"/><circle cx="9" cy="6" r="0.8" fill="#007AFF"/></svg>
          </div>
          <div>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-[8px] bg-[#007AFF]/15 text-[#007AFF] text-[13px] font-medium" style="font-family: 'Inter', sans-serif;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 2h5l3 3v5H2V2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
              @src/auth.ts
            </span>
          </div>
          <div>
            <h3 class="text-[20px] font-bold text-[#1C1C1C] mb-2 leading-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">@ File mention.<br />Context in a keystroke.</h3>
            <p class="text-[14px] text-[#6B6B6B] leading-[1.7]" style="font-family: 'Inter', sans-serif;">Type @ to inline-search your project files. Path resolves automatically on send — no copy-pasting paths.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32" style="background: #1C1C1E;">
      <div class="max-w-[640px] mx-auto px-8 text-center flex flex-col items-center gap-8">
        <p class="text-xs font-semibold tracking-[0.1em] uppercase text-[#F08C00]" style="font-family: 'Inter', sans-serif;">Download Free</p>
        <h2 class="text-[48px] font-bold leading-[1.1] tracking-[-0.02em] text-white" style="font-family: 'Bricolage Grotesque', sans-serif;">
          Ready to stop switching windows?
        </h2>
        <p class="text-[16px] text-white/50 leading-[1.7]" style="font-family: 'Inter', sans-serif;">
          Relaybox is completely free. Install in 30 seconds.
        </p>
        <div class="flex flex-col items-center gap-3">
          <a
            href="https://github.com/k-yoneda0614/relaybox/releases"
            class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-[#F08C00] text-white font-semibold text-[16px] hover:bg-[#E07D00] transition-colors"
            style="font-family: 'Inter', sans-serif;"
          >
            Download for macOS
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M3 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M1 11h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
          <p class="text-[12px] text-white/30" style="font-family: 'Inter', sans-serif;">macOS 13.0+ · Apple Silicon & Intel</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 px-8 border-t border-white/[0.06]" style="background: #1C1C1E;">
      <div class="max-w-[1280px] mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <img src="/logo.svg" alt="Relaybox" class="w-6 h-6" />
          <span class="text-white/40 text-[13px]" style="font-family: 'Bricolage Grotesque', sans-serif;">Relaybox</span>
        </div>
        <div class="flex items-center gap-6">
          <a href="https://github.com/k-yoneda0614/relaybox" class="text-white/40 hover:text-white/70 text-[13px] transition-colors" style="font-family: 'Inter', sans-serif;">GitHub</a>
          <a href="https://github.com/k-yoneda0614/relaybox/releases" class="text-white/40 hover:text-white/70 text-[13px] transition-colors" style="font-family: 'Inter', sans-serif;">Releases</a>
          <a href="https://github.com/k-yoneda0614/relaybox/issues" class="text-white/40 hover:text-white/70 text-[13px] transition-colors" style="font-family: 'Inter', sans-serif;">Issues</a>
        </div>
        <p class="text-white/30 text-[13px]" style="font-family: 'Inter', sans-serif;">© 2026 Kaito Yoneda</p>
      </div>
    </footer>
  </body>
</html>
